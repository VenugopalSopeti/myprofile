---
import '../styles/global.css';

const { title = 'S VenuGopal | Developer Profile' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Responsive developer profile for GitHub, LeetCode, HackerRank and software projects." />
    <title>{title}</title>
  </head>
  <body class="min-h-screen overflow-x-hidden bg-black text-emerald-50 antialiased">
    <slot />
  </body>
</html>
