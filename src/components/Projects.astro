---
const { projects } = Astro.props;
---
<section id="projects" class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="terminal-line font-mono text-sm text-emerald-300">repositories</p>
      <h2 class="mt-2 text-3xl font-bold text-emerald-50 sm:text-4xl">Selected Builds</h2>
      <p class="mt-2 max-w-2xl text-zinc-400">Work that shows backend thinking, security awareness, and product-minded web delivery.</p>
    </div>
  </div>
  <div class="mt-8 grid gap-5 md:grid-cols-2">
    {projects.map((project, index) => (
      <article class="code-panel rounded-2xl p-6 transition hover:-translate-y-1 hover:border-emerald-300/50">
        <div class="flex items-start justify-between gap-4">
          <h3 class="text-xl font-bold text-emerald-50">{project.name}</h3>
          <span class="rounded-md border border-emerald-400/20 bg-black/50 px-2 py-1 font-mono text-xs text-emerald-300">0{index + 1}</span>
        </div>
        <p class="mt-3 leading-7 text-zinc-300">{project.description}</p>
        <div class="mt-5 flex flex-wrap gap-2">
          {project.tags.map((tag) => <span class="rounded-md border border-emerald-400/15 bg-black/50 px-3 py-1 font-mono text-xs text-emerald-200">{tag}</span>)}
        </div>
      </article>
    ))}
  </div>
</section>
