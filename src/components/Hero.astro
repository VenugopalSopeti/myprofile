---
const { profile } = Astro.props;
const githubUrl = profile.github.url || profile.links?.find((link) => link.label === 'GitHub')?.url;
const leetcodeUrl = profile.leetcode.url || profile.links?.find((link) => link.label === 'LeetCode')?.url;
const linkedinUrl = profile.linkedin?.url || profile.links?.find((link) => link.label === 'LinkedIn')?.url;
const hackerrankUrl = profile.hackerrank?.url || profile.links?.find((link) => link.label === 'HackerRank')?.url;
const proofPoints = [
  { label: 'Experience', value: '7+ yrs' },
  { label: 'Core stack', value: 'Java + Spring' },
  { label: 'Base', value: 'Hyderabad' }
];
---
<section id="home" class="mx-auto grid max-w-6xl gap-8 px-4 py-12 sm:px-6 md:grid-cols-[1.15fr_0.85fr] md:py-18 lg:py-20">
  <div class="min-w-0">
    <div class="mb-5 flex flex-wrap items-center gap-3">
      <p class="terminal-line font-mono text-sm text-emerald-300">profile loaded</p>
      <span class="rounded-full border border-emerald-400/25 bg-emerald-400/10 px-3 py-1 font-mono text-xs text-emerald-100">{profile.location}</span>
    </div>
    <h1 class="max-w-3xl text-4xl font-black tracking-tight text-emerald-50 sm:text-5xl md:text-6xl lg:text-7xl">
      {profile.name}
    </h1>
    <p class="mt-5 max-w-3xl text-lg font-semibold leading-8 text-emerald-300 sm:text-xl">{profile.headline ?? profile.role}</p>
    <p class="muted-copy mt-6 max-w-2xl text-base leading-8 sm:text-lg">{profile.summary}</p>
    <div class="mt-7 grid gap-3 sm:grid-cols-3">
      {proofPoints.map((item) => (
        <div class="stat-tile rounded-xl border border-emerald-400/15 bg-black/45 p-4">
          <span class="block font-mono text-xs text-zinc-500">{item.label}</span>
          <strong class="mt-1 block text-emerald-50">{item.value}</strong>
        </div>
      ))}
    </div>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href={linkedinUrl} target="_blank" rel="noreferrer" class="primary-action link-focus rounded-lg bg-emerald-400 px-5 py-3 font-semibold text-black hover:bg-emerald-300">LinkedIn</a>
      <a href={githubUrl} target="_blank" rel="noreferrer" class="link-focus rounded-lg border border-emerald-400/40 px-5 py-3 font-semibold text-emerald-100 hover:border-emerald-300 hover:bg-emerald-400/10 hover:text-emerald-300">GitHub</a>
      <a href="#about" class="link-focus rounded-lg border border-white/10 px-5 py-3 font-semibold text-zinc-200 hover:border-emerald-300 hover:text-emerald-300">View Profile</a>
    </div>
  </div>
  <aside class="code-panel scanline rounded-2xl p-4 sm:p-6">
    <div class="flex items-center gap-2 border-b border-emerald-400/15 pb-4">
      <span class="h-3 w-3 rounded-full bg-emerald-400"></span>
      <span class="h-3 w-3 rounded-full bg-lime-300"></span>
      <span class="h-3 w-3 rounded-full bg-green-700"></span>
      <span class="ml-auto font-mono text-xs text-emerald-300">profile.json</span>
    </div>
    <div class="mt-5 space-y-4 font-mono text-sm">
      <p class="text-zinc-400">"role": <span class="text-emerald-300">"Software Developer"</span></p>
      <p class="text-zinc-400">"focus": <span class="text-emerald-300">"secure backend systems"</span></p>
      <p class="text-zinc-400">"lastUpdated": <span class="break-words text-emerald-300">"{profile.lastUpdated}"</span></p>
      <div class="grid gap-3 sm:grid-cols-2 md:grid-cols-1 lg:grid-cols-2">
        <a href={githubUrl} target="_blank" rel="noreferrer" class="rounded-lg border border-emerald-400/15 bg-black/50 p-4 transition hover:border-emerald-300/60 hover:bg-emerald-400/10">
          <span class="block text-zinc-500">github</span>
          <strong class="mt-1 block truncate text-emerald-100">@{profile.github.username}</strong>
        </a>
        <a href={leetcodeUrl} target="_blank" rel="noreferrer" class="rounded-lg border border-emerald-400/15 bg-black/50 p-4 transition hover:border-emerald-300/60 hover:bg-emerald-400/10">
          <span class="block text-zinc-500">leetcode</span>
          <strong class="mt-1 block truncate text-emerald-100">@{profile.leetcode.username}</strong>
        </a>
        <a href={hackerrankUrl} target="_blank" rel="noreferrer" class="rounded-lg border border-emerald-400/15 bg-black/50 p-4 transition hover:border-emerald-300/60 hover:bg-emerald-400/10">
          <span class="block text-zinc-500">hackerrank</span>
          <strong class="mt-1 block truncate text-emerald-100">@{profile.hackerrank.username}</strong>
        </a>
        <a href={linkedinUrl} target="_blank" rel="noreferrer" class="rounded-lg border border-emerald-400/15 bg-black/50 p-4 transition hover:border-emerald-300/60 hover:bg-emerald-400/10">
          <span class="block text-zinc-500">linkedin</span>
          <strong class="mt-1 block truncate text-emerald-100">connect</strong>
        </a>
      </div>
    </div>
  </aside>
</section>
